<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@color/facebook_siva"
    tools:context=".Registracija">

    <LinearLayout
        android:layout_width="333dp"
        android:layout_height="664dp"
        android:layout_gravity="center"
        android:background="@color/plava"
        android:orientation="vertical">

        <TextView
            android:id="@+id/loginText"
            android:layout_width="333dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:alpha="0.9"
            android:paddingTop="14dp"
            android:shadowColor="@color/black"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"
            android:text="@string/registujte_se"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="24dp"
            android:layout_marginRight="24dp"
            android:layout_marginBottom="10dp"
            android:hint="@string/ime"
            android:textColorHint="@color/md_theme_secondaryContainer"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/md_theme_secondaryContainer"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintTextColor="@color/md_theme_secondaryContainer">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/imeKorisnika"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:textColor="@color/black"
                android:textStyle="bold" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="24dp"
            android:layout_marginRight="24dp"
            android:layout_marginBottom="10dp"
            android:hint="@string/prezime"
            android:textColorHint="@color/md_theme_secondaryContainer"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/md_theme_secondaryContainer"
            app:boxStrokeWidth="0.9dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintTextColor="@color/md_theme_secondaryContainer">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/prezimeKorisnika"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@color/white"
                android:inputType="text"
                android:textColor="@color/black"
                android:textColorHint="#615656"
                android:textStyle="bold" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="24dp"
            android:layout_marginRight="24dp"
            android:layout_marginBottom="10dp"
            android:hint="@string/Email"
            android:textColorHint="@color/md_theme_secondaryContainer"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/md_theme_secondaryContainer"
            app:boxStrokeWidth="0.9dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintTextColor="@color/md_theme_secondaryContainer">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextEmailAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:textColor="@color/black"
                android:textStyle="bold" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="24dp"
            android:layout_marginRight="24dp"
            android:layout_marginBottom="10dp"
            android:hint="@string/password"
            android:textColorHint="@color/md_theme_secondaryContainer"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/md_theme_secondaryContainer"
            app:boxStrokeWidth="0.9dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/black"
            app:hintTextColor="@color/md_theme_secondaryContainer">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="Password"
                android:inputType="textPassword"
                android:textColor="@color/black"
                android:textColorHint="#615656"
                android:textStyle="bold" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="24dp"
            android:layout_marginRight="24dp"
            android:layout_marginBottom="10dp"
            android:hint="@string/Username"
            android:textColorHint="@color/md_theme_secondaryContainer"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/md_theme_secondaryContainer"
            app:boxStrokeWidth="0.9dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintTextColor="@color/md_theme_secondaryContainer">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/UsernameKorisnika"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@color/white"
                android:inputType="text"
                android:textColor="@color/black"
                android:textColorHint="#615656"
                android:textStyle="bold" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="24dp"
            android:layout_marginRight="24dp"
            android:layout_marginBottom="10dp"
            android:hint="@string/Telefon"
            android:textColorHint="@color/md_theme_secondaryContainer"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/md_theme_secondaryContainer"
            app:boxStrokeWidth="0.9dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintTextColor="@color/md_theme_secondaryContainer">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/telefonKorisnika"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@color/white"
                android:inputType="text"
                android:textColor="@color/black"
                android:textColorHint="#615656"
                android:textStyle="bold" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="24dp"
            android:layout_marginRight="24dp"
            android:layout_marginBottom="10dp"
            android:hint="@string/Mesto"
            android:textColorHint="@color/md_theme_secondaryContainer"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="@color/md_theme_secondaryContainer"
            app:boxStrokeWidth="0.9dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintTextColor="@color/md_theme_secondaryContainer">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/mestoKorisnika"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@color/white"
                android:inputType="text"
                android:textColor="@color/black"
                android:textColorHint="#615656"
                android:textStyle="bold" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/loginButton"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:onClick="registerUser"
            android:text="@string/registujte_se"
            android:textColor="@color/plava"
            android:textSize="18sp"
            app:cornerRadius="20dp" />


    </LinearLayout>
</LinearLayout>